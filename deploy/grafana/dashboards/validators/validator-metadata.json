  "panels": [
    {
      "type": "row",
      "title": "Binary drift — RPC /status.node_info",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1000,
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Distinct values of the version label across fleet. 1 = agreement, ≥2 = version drift.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "count(count by (version) (max by (validator, version) (last_over_time(sentinel_node_build_info[1m]))))",
          "legendFormat": "distinct values",
          "refId": "A"
        }
      ],
      "title": "Version agreement",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Distinct values of chain_id. Divergence means you're running two different chains.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "count(count by (chain_id) (max by (validator, chain_id) (last_over_time(sentinel_node_build_info[1m]))))",
          "legendFormat": "distinct values",
          "refId": "A"
        }
      ],
      "title": "Chain ID agreement",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Per-validator build identity (from /status.node_info) joined with the sentry's own build identity when the beacon is deployed (sentry_moniker/sentry_version come from sentinel_sentry_info). A validator vs. sentry version gap is a deployment drift signal.",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "align": "auto", "cellOptions": { "type": "auto" } }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "id": 4,
      "options": { "showHeader": true },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "max by (validator, chain_id, moniker, version) (last_over_time(sentinel_node_build_info{validator=~\"$validator\"}[1m]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "max by (validator, sentry_moniker, sentry_version) (last_over_time(sentinel_sentry_info{validator=~\"$validator\"}[1m]))",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "title": "Build info — validator + sentry per row",
      "type": "table",
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "validator", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Value #A": true,
              "Value #B": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "job 1": true,
              "job 2": true,
              "instance 1": true,
              "instance 2": true
            },
            "renameByName": {},
            "indexByName": {
              "validator": 0,
              "chain_id": 1,
              "version": 2,
              "moniker": 3,
              "sentry_moniker": 4,
              "sentry_version": 5
            }
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "validator",
                "chain_id",
                "version",
                "moniker",
                "sentry_moniker",
                "sentry_version"
              ]
            }
          }
        }
      ]
    },
