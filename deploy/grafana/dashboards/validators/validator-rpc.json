              "options": {
                "1": {
                  "text": "propose",
                  "color": "blue",
                  "index": 0
                },
                "2": {
                  "text": "prevote",
                  "color": "yellow",
                  "index": 1
                },
                "3": {
                  "text": "precommit",
                  "color": "orange",
                  "index": 2
                },
                "4": {
                  "text": "commit",
                  "color": "green",
                  "index": 3
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
