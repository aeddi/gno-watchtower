    {
      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "description": "Mean interval between successive blocks over the last rate window. gnoland targets ~3s. A stall clamps the denominator so the cell shows a huge-but-finite value rather than +Inf.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "id": 3,
