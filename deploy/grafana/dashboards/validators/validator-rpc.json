          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "victoriametrics"
          },
          "expr": "max by (validator) (sentinel_rpc_latest_block_height{validator=~\"$validator\"})",
          "legendFormat": "{{validator}}",
          "refId": "A"
        }
      ],
      "title": "Latest block height",
