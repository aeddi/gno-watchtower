    {
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "description": "Average interval between consecutive blocks as observed by each validator. Computed over the rate window so a stalled chain reads as a rising mean. gnoland emits this in seconds.",
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "decimals": 2, "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1}, "color": {"mode": "palette-classic"}}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "options": {"legend": {"calcs": ["last", "mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "all", "sort": "desc"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "victoriametrics"}, "expr": "sum by (validator) (rate(block_interval_hist_sum{validator=~\"$validator\"}[$__rate_interval])) / clamp_min(sum by (validator) (rate(block_interval_hist_count{validator=~\"$validator\"}[$__rate_interval])), 1e-9)", "legendFormat": "{{validator}}", "refId": "A"}
      ],
      "title": "Avg block interval",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "description": "Average block size in bytes over the rate window.",
