              "job 2": true,
              "instance 1": true,
              "instance 2": true,
              "id 1": true,
              "id 2": true,
              "image 1": true,
              "image 2": true
            },
            "renameByName": {
              "Value #A": "cpu",
              "Value #B": "memory"
            },
            "indexByName": {
              "name": 0,
              "cpu": 1,
              "memory": 2
            }
          }
        },
