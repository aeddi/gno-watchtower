{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "title": "Validator chain",
      "type": "link",
      "icon": "external link",
      "targetBlank": false,
      "tooltip": "Block height, peers, mempool, consensus quorum",
      "url": "/d/validator-chain/validator-chain?${__url_time_range}&${validator:queryparam}"
    },
    {
      "title": "Validator metadata",
      "type": "link",
      "icon": "external link",
      "targetBlank": false,
      "tooltip": "Chain ID, moniker, binary, genesis, config keys",
      "url": "/d/validator-metadata/validator-metadata?${__url_time_range}&${validator:queryparam}"
    },
    {
      "title": "Validator resources",
      "type": "link",
      "icon": "external link",
      "targetBlank": false,
      "tooltip": "Per-validator host + container resources",
      "url": "/d/validator-resources/validator-resources?${__url_time_range}&${validator:queryparam}"
    },
    {
      "title": "Validator logs",
      "type": "link",
      "icon": "external link",
      "targetBlank": false,
      "tooltip": "Per-validator log browser (Loki)",
      "url": "/d/validator-logs/validator-logs?${__url_time_range}&${validator:queryparam}"
    },
    {
      "title": "Watchtower resources",
      "type": "link",
      "icon": "external link",
      "targetBlank": false,
      "tooltip": "Watchtower host + container resources",
      "url": "/d/watchtower-resources/watchtower-resources?${__url_time_range}&${validator:queryparam}"
    }
  ],
  "panels": [
    {
      "type": "row",
      "title": "Pipeline health — sentinel side",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1000,
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Payload bytes per second before compression (i.e. what the sentinel produced). Stacked per (validator, type). Counters are sent from the sentinel's stats.Stats snapshot every 30s — rate() window should be ≥2× that.",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": {
          "calcs": ["last", "mean", "max"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "all", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum by (validator, type) (rate(sentinel_self_bytes_sent_total{encoding=\"uncompressed\", validator=~\"$validator\"}[$__rate_interval]))",
          "legendFormat": "{{validator}} / {{type}}",
          "refId": "A"
        }
      ],
      "title": "Uncompressed production (per validator × type)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Post-compression (wire) bytes per second. For rpc/metrics/otlp this equals the uncompressed rate; for logs the ratio shows the zstd savings. Compare against the panel on the left to eyeball compression impact.",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": {
        "legend": {
          "calcs": ["last", "mean", "max"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "all", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum by (validator, type) (rate(sentinel_self_bytes_sent_total{encoding=\"wire\", validator=~\"$validator\"}[$__rate_interval]))",
          "legendFormat": "{{validator}} / {{type}}",
          "refId": "A"
        }
      ],
      "title": "Wire traffic (per validator × type)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Logs compression ratio: uncompressed/wire. 1.0 = no savings; 4-5x is typical for JSON line logs under zstd. Other types are effectively 1.0 because they are not compressed on wire.",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "min": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["last", "mean"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "all", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum by (validator) (rate(sentinel_self_bytes_sent_total{type=\"logs\", encoding=\"uncompressed\", validator=~\"$validator\"}[$__rate_interval])) / clamp_min(sum by (validator) (rate(sentinel_self_bytes_sent_total{type=\"logs\", encoding=\"wire\", validator=~\"$validator\"}[$__rate_interval])), 1e-9)",
          "legendFormat": "{{validator}}",
          "refId": "A"
        }
      ],
      "title": "Logs compression ratio (uncompressed ÷ wire)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Payloads dropped at the sentinel when its per-type buffer was full (the watchtower was slow or unreachable long enough to overflow). Any non-zero sustained value is a data-loss signal.",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 9 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum by (validator) (increase(sentinel_self_drops_total{validator=~\"$validator\"}[$__range]))",
          "legendFormat": "{{validator}}",
          "refId": "A"
        }
      ],
      "title": "Drops (range total)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Send retries from the sentinel — counts attempts after a failed POST. Sustained retries indicate a flaky link or an overloaded watchtower.",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 50 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 9 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum by (validator) (increase(sentinel_self_retries_total{validator=~\"$validator\"}[$__range]))",
          "legendFormat": "{{validator}}",
          "refId": "A"
        }
      ],
      "title": "Retries (range total)",
      "type": "stat"
    },
    {
      "type": "row",
      "title": "Pipeline health — watchtower side",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 1001,
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Bytes received per second at the watchtower, from validator×type. Source: watchtower_received_bytes_total counter (scraped from watchtower:8080/metrics every 15s).",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 6,
      "options": {
        "legend": {
          "calcs": ["last", "mean", "max"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "all", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum by (validator, type) (rate(watchtower_received_bytes_total{validator=~\"$validator\"}[$__rate_interval]))",
          "legendFormat": "{{validator}} / {{type}}",
          "refId": "A"
        }
      ],
      "title": "Received throughput (per validator × type)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Payloads per second received at the watchtower. Useful cross-check: if bytes/sec is steady but payloads/sec drops, individual payloads are getting larger (buffered up somewhere).",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 7,
      "options": {
        "legend": {
          "calcs": ["last", "mean", "max"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "all", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum by (validator, type) (rate(watchtower_received_payloads_total{validator=~\"$validator\"}[$__rate_interval]))",
          "legendFormat": "{{validator}} / {{type}}",
          "refId": "A"
        }
      ],
      "title": "Received payload rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Sentinel-side wire rate minus watchtower-side received rate per validator. Expected near zero in steady state. Positive = in-flight bytes not yet received (transient during a slow watchtower). Persistent positive = loss / failing retries / network backpressure.",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "id": 8,
      "options": {
        "legend": {
          "calcs": ["last", "mean"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "all", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum by (validator) (rate(sentinel_self_bytes_sent_total{encoding=\"wire\", validator=~\"$validator\"}[$__rate_interval])) - sum by (validator) (rate(watchtower_received_bytes_total{validator=~\"$validator\"}[$__rate_interval]))",
          "legendFormat": "{{validator}}",
          "refId": "A"
        }
      ],
      "title": "Sentinel sent − watchtower received (should be ~0)",
      "type": "timeseries"
    },
    {
      "type": "row",
      "title": "Production rates per validator",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 1002,
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Projected uncompressed production per hour by type. 1h rate × 3600s.",
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" } },
          "color": { "mode": "thresholds" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "logs_per_hour" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "gradient" }
              },
              { "id": "color", "value": { "mode": "continuous-BlYlRd" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "rpc_per_hour" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "gradient" }
              },
              { "id": "color", "value": { "mode": "continuous-BlYlRd" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "metrics_per_hour" },
            "properties": [
              { "id": "unit", "value": "bytes" },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "gradient" }
              },
              { "id": "color", "value": { "mode": "continuous-BlYlRd" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 35 },
      "id": 9,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "logs_per_hour" }]
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum by (validator) (rate(sentinel_self_bytes_sent_total{type=\"logs\", encoding=\"uncompressed\", validator=~\"$validator\"}[1h])) * 3600",
          "legendFormat": "{{validator}}",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum by (validator) (rate(sentinel_self_bytes_sent_total{type=\"rpc\", encoding=\"uncompressed\", validator=~\"$validator\"}[1h])) * 3600",
          "legendFormat": "{{validator}}",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum by (validator) (rate(sentinel_self_bytes_sent_total{type=\"metrics\", encoding=\"uncompressed\", validator=~\"$validator\"}[1h])) * 3600",
          "legendFormat": "{{validator}}",
          "refId": "C",
          "format": "table",
          "instant": true
        }
      ],
      "title": "Bytes/hour per validator (by type)",
      "type": "table",
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "validator", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "job 1": true,
              "job 2": true,
              "job 3": true,
              "instance 1": true,
              "instance 2": true,
              "instance 3": true
            },
            "renameByName": {
              "Value #A": "logs_per_hour",
              "Value #B": "rpc_per_hour",
              "Value #C": "metrics_per_hour"
            },
            "indexByName": {
              "validator": 0,
              "logs_per_hour": 1,
              "rpc_per_hour": 2,
              "metrics_per_hour": 3
            }
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "validator",
                "logs_per_hour",
                "rpc_per_hour",
                "metrics_per_hour"
              ]
            }
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Storage & retention",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "id": 1003,
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Active data volume held by VictoriaMetrics. Source: vm_data_size_bytes (VM self-scrape).",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50000000000 },
              { "color": "red", "value": 100000000000 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 44 },
      "id": 10,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum(vm_data_size_bytes)",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "VM stored data",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Cumulative bytes Loki has flushed to backing storage through its ingester (loki_ingester_chunk_size_bytes_sum). Data written since Loki started; retention eventually purges older chunks from disk, so after one full retention window this number will exceed actual on-disk use. Good proxy for ingest volume.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50000000000 },
              { "color": "red", "value": 100000000000 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 44 },
      "id": 11,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "sum(loki_ingester_chunk_size_bytes_sum)",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Loki data written (cumulative)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Configured VictoriaMetrics retention window. Read from the watchtower's /metrics endpoint (gauge, set once at startup from METRICS_RETENTION).",
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "text" }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 44 },
      "id": 12,
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "watchtower_config_retention_seconds{backend=\"vm\"} / 86400",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "VM retention (days)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "Configured Loki retention window. Read from the watchtower's /metrics endpoint (gauge, set once at startup from LOGS_RETENTION).",
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "text" }
        },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 44 },
      "id": 13,
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoriametrics" },
          "expr": "watchtower_config_retention_seconds{backend=\"loki\"} / 86400",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Loki retention (days)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "description": "VM data-volume disk footprint (from VM's self-scrape) against the retention-bound capacity. predict_linear projects where storage will be in {retention window} based on the last 7d trend — caveat: linear fit assumes steady ingest, any rapid increase in validator count or logging will outrun this.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
