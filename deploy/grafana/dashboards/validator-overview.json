{
  "__inputs": [],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Overview of all validators: total log lines seen, error rates, and stream counts.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "title": "Validator Drilldown",
      "type": "dashboard",
      "url": "/d/validator-drilldown/validator-drilldown"
    }
  ],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({level=~\"error|warn\"}[1h]))",
          "legendFormat": "Errors+Warns (1h)",
          "refId": "A"
        }
      ],
      "title": "Total Error/Warn Lines (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count(count by (validator) ({validator=~\".+\"}))",
          "legendFormat": "Active Validators",
          "refId": "A"
        }
      ],
      "title": "Active Validators",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Validator" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Drilldown",
                    "url": "/d/validator-drilldown/validator-drilldown?var-validator=${__data.fields.Validator}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "id": 3,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (validator) (count_over_time({validator=~\".+\"}[1h]))",
          "instant": true,
          "legendFormat": "{{validator}}",
          "refId": "A"
        }
      ],
      "title": "Log Stream Counts per Validator (1h)",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "valueLabel": "validator" }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "validator": "Validator",
              "Value": "Log Lines (1h)"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["validators", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Validator Overview",
  "uid": "validator-overview",
  "version": 1
}
