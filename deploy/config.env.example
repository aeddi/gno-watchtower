# Copy this to config.env and fill in real values.

# Public domain for Caddy TLS and Grafana access.
DOMAIN=monitoring.example.com

# Grafana admin credentials.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# VictoriaMetrics retention period in months.
METRICS_RETENTION=6

# Loki log retention period (e.g. 2160h = 90 days).
LOGS_RETENTION=2160h
